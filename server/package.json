{
  "name": "server",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "auth:generate": "bun --bun better-auth generate --output ./src/db/schema/auth.ts -y",
    "db:generate": "bun drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bun --bun drizzle-kit migrate --config drizzle.config.ts",
    "db:prepare": "bun run auth:generate && bun run db:generate && bun run db:migrate",
    "db:studio": "bun --bun drizzle-kit studio --config drizzle.config.ts"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@types/bun": "^1.3.10",
    "drizzle-kit": "^0.31.9"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "overrides": {
    "@sinclair/typebox": "0.34.48"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.5.5",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "better-auth": "^1.5.5",
    "drizzle-orm": "^0.45.1",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.4.27"
  },
  "trustedDependencies": [
    "@better-auth/cli"
  ]
}
