{
  "name": "server",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "auth:generate": "bun --bun better-auth generate --output ./src/db/schema/auth.ts -y",
    "db:generate": "bun --bun drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "bun --bun drizzle-kit migrate --config drizzle.config.ts",
    "db:prepare": "bun run auth:generate && bun run db:generate && bun run db:migrate",
    "db:studio": "bun --bun drizzle-kit studio --config drizzle.config.ts",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "build": "bun build --compile --minify-whitespace --minify-syntax --outfile server src/index.ts"
  },
  "devDependencies": {
    "@better-auth/cli": "^1.4.21",
    "@biomejs/biome": "2.4.8",
    "@types/bun": "^1.3.11",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^5.9.3"
  },
  "overrides": {
    "@sinclair/typebox": "0.34.48"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.5.6",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/openapi": "^1.4.14",
    "@simplewebauthn/server": "^13.3.0",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.45.2",
    "drizzle-typebox": "^0.3.3",
    "elysia": "^1.4.28"
  },
  "trustedDependencies": [
    "@better-auth/cli"
  ]
}
